{
  "name": "archassistant-vscode",
  "displayName": "ArchAssistant",
  "description": "AI-powered code generation with architectural control",
  "version": "0.2.0",
  "publisher": "archassistant",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:archassistant.startProject",
    "onCommand:archassistant.configureProject",
    "onCommand:archassistant.generateCode",
    "onCommand:archassistant.showMetrics",
    "onCommand:archassistant.exportMetrics",
    "onCommand:archassistant.getActualRules",
    "onCommand:archassistant.refreshRules",
    "onCommand:archassistant.saveRules",
    "onView:archassistant.projectInfo",
    "onView:archassistant.rulesList"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "archassistant.startProject",
        "title": "ArchAssistant: Start Project"
      },
      {
        "command": "archassistant.configureProject",
        "title": "ArchAssistant: Configure Project"
      },
      {
        "command": "archassistant.generateCode",
        "title": "ArchAssistant: Generate Code"
      },
      {
        "command": "archassistant.showMetrics",
        "title": "ArchAssistant: Show Metrics"
      },
      {
        "command": "archassistant.exportMetrics",
        "title": "ArchAssistant: Export Metrics"
      },
      {
        "command": "archassistant.getActualRules",
        "title": "ArchAssistant: Get Actual Rules"
      },
      {
        "command": "archassistant.refreshRules",
        "title": "ArchAssistant: Refresh Rules"
      },
      {
        "command": "archassistant.saveRules",
        "title": "ArchAssistant: Save Rules"
      },
      {
        "command": "archassistant.toggleRule",
        "title": "ArchAssistant: Toggle Rule"
      },
      {
        "command": "archassistant.editRule",
        "title": "ArchAssistant: Edit Rule"
      },
      {
        "command": "archassistant.deleteRule",
        "title": "ArchAssistant: Delete Rule"
      },
      {
        "command": "archassistant.addCustomRule",
        "title": "ArchAssistant: Add Custom Rule"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "archassistant-sidebar",
          "title": "ArchAssistant",
          "icon": "resources/archassistant.svg"
        }
      ]
    },
    "views": {
      "archassistant-sidebar": [
        {
          "id": "archassistant.projectInfo",
          "name": "Project",
          "icon": "resources/archassistant.svg"
        },
        {
          "id": "archassistant.rulesList",
          "name": "Rules",
          "icon": "resources/archassistant.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "archassistant.startProject",
          "when": "view == archassistant.projectInfo",
          "group": "navigation@1"
        },
        {
          "command": "archassistant.configureProject",
          "when": "view == archassistant.projectInfo",
          "group": "navigation@2"
        },
        {
          "command": "archassistant.generateCode",
          "when": "view == archassistant.projectInfo",
          "group": "navigation@3"
        },
        {
          "command": "archassistant.showMetrics",
          "when": "view == archassistant.projectInfo",
          "group": "navigation@4"
        },
        {
          "command": "archassistant.getActualRules",
          "when": "view == archassistant.rulesList",
          "group": "navigation@1"
        },
        {
          "command": "archassistant.refreshRules",
          "when": "view == archassistant.rulesList",
          "group": "navigation@2"
        },
        {
          "command": "archassistant.saveRules",
          "when": "view == archassistant.rulesList",
          "group": "navigation@3"
        },
        {
          "command": "archassistant.addCustomRule",
          "when": "view == archassistant.rulesList",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "archassistant.toggleRule",
          "when": "view == archassistant.rulesList && viewItem == savedRule",
          "group": "inline@1"
        },
        {
          "command": "archassistant.editRule",
          "when": "view == archassistant.rulesList && viewItem == savedRule",
          "group": "inline@2"
        },
        {
          "command": "archassistant.deleteRule",
          "when": "view == archassistant.rulesList && viewItem == savedRule",
          "group": "inline@3"
        },
        {
          "command": "archassistant.addCustomRule",
          "when": "view == archassistant.rulesList && viewItem == suggestedRule",
          "group": "inline@1"
        }
      ]
    },
    "configuration": {
      "title": "ArchAssistant",
      "properties": {
        "archassistant.backendUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "Backend API URL"
        },
        "archassistant.composeDirectory": {
          "type": "string",
          "default": "",
          "description": "Directory with docker-compose.yml"
        },
        "archassistant.composeServiceName": {
          "type": "string",
          "default": "backend",
          "description": "Docker Compose service name"
        },
        "archassistant.autoStartBackend": {
          "type": "boolean",
          "default": true,
          "description": "Start backend automatically"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.80.0",
    "@vscode/test-electron": "^2.3.10",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "axios": "^1.7.2"
  }
}