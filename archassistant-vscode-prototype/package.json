{
  "name": "archassistant-vscode",
  "displayName": "ArchAssistant",
  "description": "VS Code extension for ArchAssistant: project setup, rule suggestions, and YAML rule management.",
  "version": "0.1.0",
  "publisher": "openai",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:archassistant.start",
    "onCommand:archassistant.configureProject",
    "onCommand:archassistant.refreshRules",
    "onCommand:archassistant.saveRules",
    "onCommand:archassistant.toggleRule",
    "onCommand:archassistant.editRule",
    "onCommand:archassistant.deleteRule",
    "onCommand:archassistant.addCustomRule",
    "onView:archassistantRulesView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "archassistant.start",
        "title": "ArchAssistant: Start"
      },
      {
        "command": "archassistant.configureProject",
        "title": "ArchAssistant: Configure Project"
      },
      {
        "command": "archassistant.refreshRules",
        "title": "ArchAssistant: Refresh Rules"
      },
      {
        "command": "archassistant.saveRules",
        "title": "ArchAssistant: Save Rules"
      },
      {
        "command": "archassistant.toggleRule",
        "title": "ArchAssistant: Toggle Rule"
      },
      {
        "command": "archassistant.editRule",
        "title": "ArchAssistant: Edit Rule"
      },
      {
        "command": "archassistant.deleteRule",
        "title": "ArchAssistant: Delete Rule"
      },
      {
        "command": "archassistant.addCustomRule",
        "title": "ArchAssistant: Add Custom Rule"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "archassistantContainer",
          "title": "ArchAssistant",
          "icon": "resources/archunit.svg"
        }
      ]
    },
    "views": {
      "archassistantContainer": [
        {
          "id": "archassistantRulesView",
          "name": "Rules",
          "icon": "resources/archunit.svg"
        }
      ]
    },
    "configuration": {
      "title": "ArchAssistant",
      "properties": {
        "archassistant.backendUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "Base URL of the ArchAssistant backend"
        },
        "archassistant.composeDirectory": {
          "type": "string",
          "default": "",
          "description": "Working directory containing docker-compose.yml for the backend"
        },
        "archassistant.composeServiceName": {
          "type": "string",
          "default": "backend",
          "description": "Docker Compose service name for the backend"
        },
        "archassistant.autoStartBackend": {
          "type": "boolean",
          "default": true,
          "description": "Start the backend automatically when using ArchAssistant: Start"
        }
      }
    },
    "menus": {
      "view/item/context": [
        {
          "command": "archassistant.toggleRule",
          "when": "view == archassistantRulesView && viewItem == savedRule",
          "group": "inline@1"
        },
        {
          "command": "archassistant.editRule",
          "when": "view == archassistantRulesView && viewItem == savedRule",
          "group": "inline@2"
        },
        {
          "command": "archassistant.deleteRule",
          "when": "view == archassistantRulesView && viewItem == savedRule",
          "group": "inline@3"
        },
        {
          "command": "archassistant.addCustomRule",
          "when": "view == archassistantRulesView && viewItem == suggestedRule",
          "group": "inline@1"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "lint": "echo 'Add linting if needed'",
    "test": "echo 'Add tests if needed'"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.5.4"
  }
}